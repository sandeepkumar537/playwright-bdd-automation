# Secrets Configuration (Keep secure, add real secrets.toml to .gitignore)
# Copy this file to secrets.toml and add real values

[environment.dev.database]
password = "dev_password"

[environment.dev]
api_key = "dev_api_key"
auth_token = "dev_auth_token"

[environment.staging.database]
password = "staging_password"

[environment.staging]
api_key = "staging_api_key"
auth_token = "staging_auth_token"

[environment.prod.database]
password = "prod_password"

[environment.prod]
api_key = "prod_api_key"
auth_token = "prod_auth_token"
